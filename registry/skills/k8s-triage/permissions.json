{
  "always_allow": [
    {
      "pattern": "\"command\"\\s*:\\s*\"\\s*kubectl\\s+(get|describe|logs|top|explain|version|cluster-info|api-resources|api-versions|auth\\s+can-i)\\b",
      "reason": "read-only kubectl subcommands"
    },
    {
      "pattern": "\"command\"\\s*:\\s*\"\\s*kubectl\\s+config\\s+(current-context|get-contexts|view|get-clusters|get-users)\\b",
      "reason": "read-only kubectl config subcommands"
    },
    {
      "pattern": "\"command\"\\s*:\\s*\"\\s*kubectl\\s+(diff|wait)\\b",
      "reason": "kubectl diff/wait are non-mutating"
    }
  ],
  "ask_user": [
    {
      "pattern": "\\bkubectl\\s+(apply|delete|patch|edit|scale|rollout|drain|cordon|uncordon|create|replace|exec|cp|port-forward|annotate|label|taint|set)\\b",
      "reason": "kubectl operation with cluster side effects — confirm namespace and target before running"
    },
    {
      "pattern": "\\bkubectl\\s+--context\\s",
      "reason": "explicit --context selects a non-default cluster — confirm the target cluster"
    }
  ]
}
