{
  "permissions": {
    "defaultMode": "default",
    "deny": [
      {
        "regex": "\\brm\\s+-[rRfF]+\\s+(/|~|\\$HOME)(\\s|\"|$|;|&|\\|)",
        "reason": "rm -r/-f on /, $HOME, or ~ is catastrophic",
        "tools": ["Bash"]
      },
      {
        "regex": "\\brm\\s+-[rRfF]+\\s+/(etc|usr|bin|sbin|lib|lib64|boot|home|var|opt|sys|proc|dev|root|srv|run)(\\b|/)",
        "reason": "rm -r/-f on a system directory is catastrophic",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bmkfs(\\.[a-z0-9]+)?\\b",
        "reason": "creating a filesystem destroys all data on the target device",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bdd\\b[^\"]*\\bof=/dev/(sd[a-z]|hd[a-z]|nvme|mmcblk|loop|disk|sr[0-9]|xvd|vd[a-z])",
        "reason": "dd to a block device destroys all data on it",
        "tools": ["Bash"]
      },
      {
        "regex": ":\\s*\\(\\s*\\)\\s*\\{[^}]*\\}\\s*;\\s*:",
        "reason": "fork bomb pattern",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bchattr\\s+\\+i\\b",
        "reason": "setting the immutable attribute is suspect and rarely intended",
        "tools": ["Bash"]
      },
      {
        "regex": "/etc/(shadow|gshadow|sudoers|sudoers\\.d)\\b",
        "reason": "system credential files (shadow, gshadow, sudoers) must not be read or modified by the agent"
      },
      {
        "regex": "(>>?|\\btee\\b|\\bcat\\s+>\\s*)\\s*/etc/(passwd|hosts|fstab|crontab|cron\\.d)\\b",
        "reason": "modifying system boot/host files is forbidden",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(curl|wget)\\b[^\"]*\\|\\s*(sudo\\s+)?(ba)?sh\\b",
        "reason": "piping a remote payload into a shell is a classic attack vector",
        "tools": ["Bash"]
      },
      {
        "regex": "--no-verify\\b",
        "reason": "bypassing git hooks is forbidden — fix the failing hook instead",
        "tools": ["Bash"]
      },
      {
        "regex": "--no-gpg-sign\\b|commit\\.gpgsign\\s*=\\s*false",
        "reason": "bypassing GPG signing is forbidden",
        "tools": ["Bash"]
      },
      {
        "regex": "\\biptables\\s+-F\\b|\\bufw\\s+disable\\b|\\bsystemctl\\s+(stop|disable)\\s+(firewalld|ufw|nftables)\\b",
        "reason": "disabling the host firewall is forbidden",
        "tools": ["Bash"]
      },
      {
        "regex": "(?i)^(write|edit|revert) .*\"file_path\"\\s*:\\s*\"softskills/",
        "reason": "softskills/ is curator-managed; use curate_session instead"
      },
      {
        "regex": "\"command\":\"[^\"]*(>>?|\\btee\\b|\\brm\\b|\\bmv\\b|\\bcp\\b)[^\"]*softskills/",
        "reason": "softskills/ is curator-managed; use curate_session instead",
        "tools": ["Bash"]
      },
      {
        "regex": "(?i)^(write|edit|revert) .*\"file_path\"\\s*:\\s*\"(/etc/omnis/|/etc/passwd|/etc/shadow|/etc/sudoers)",
        "reason": "writing to system config from a tool is forbidden — use the web UI editor"
      },
      {
        "regex": "\\.ssh/(id_(rsa|dsa|ecdsa|ed25519)([^.\\w]|$)|authorized_keys\\b)",
        "reason": "private SSH keys and authorized_keys must not be read or modified by the agent"
      },
      {
        "regex": "\\.aws/credentials\\b|\\.aws/config\\b|\\.config/gcloud/[^/]*credentials|\\.azure/credentials\\b",
        "reason": "cloud provider credential files must not be read or modified by the agent"
      }
    ],
    "allow": [
      "teammate_check",
      "teammate_list",
      "teammate_ask",
      "teammate_tell",
      "list_skills",
      "load_skill",
      "list_softskills",
      "load_softskill",
      "load_softskill_resource",
      "todo_read",
      "todo_write",
      "todo_update",
      "task_list",
      "task_next",
      "TaskCreate",
      "TaskUpdate",
      "compact_now",
      "AskUserQuestion",
      "bg_list",
      "curate_session",
      "recall_softskills",
      "recall_precedents",
      "search_code",
      "search_registries",
      "search_docs",
      "list_docs",
      "read_doc",
      "grep_docs",
      "list_registries",
      "browse_registry",
      "list_installed_skills",
      "get_installed_skill",
      "get_remote_skill",
      "get_remote_item",
      "investigator",
      "web_agent",
      "image_generator",
      "summariser",
      "skill_editor",
      "helper",
      "agentmd_reviewer",
      "k8s_investigator",
      "doc_agent",
      "Read",
      "Edit(//tmp/**)",
      "Bash(pandoc *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(go fmt *)",
      "Bash(go mod tidy *)",
      "Bash(go mod download *)",
      "Bash(go mod verify *)",
      "Bash(go mod graph *)",
      "Bash(go list *)",
      "Bash(go env *)",
      "Bash(go version *)",
      "Bash(go doc *)",
      "Bash(git fetch *)",
      "Bash(npm test *)",
      "Bash(npm run build *)",
      "Bash(npm run lint *)",
      "Bash(npm run typecheck *)",
      "Bash(npm ls *)",
      "Bash(npm view *)",
      "Bash(docker ps *)",
      "Bash(docker images *)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)",
      "Bash(docker version *)",
      "Bash(docker info *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl top *)",
      "Bash(kubectl explain *)",
      "Bash(kubectl version *)",
      "Bash(kubectl cluster-info *)",
      "Bash(kubectl api-resources *)",
      "Bash(kubectl api-versions *)",
      "Bash(kubectl config current-context *)",
      "Bash(kubectl config get-contexts *)",
      "Bash(kubectl config view *)",
      "Bash(kubectl auth can-i *)",
      "Bash(kubectl events *)",
      "Bash(make test *)",
      "Bash(make build *)",
      "Bash(make fmt *)",
      "Bash(make vet *)",
      "Bash(make lint *)",
      "Bash(make check *)",
      "Bash(make tidy *)",
      "Bash(just test *)",
      "Bash(just build *)",
      "Bash(just fmt *)",
      "Bash(just check *)"
    ],
    "ask": [
      "Bash(rm *)",
      {
        "regex": "\\b(mv|cp)\\s+[^\"]*\\s+(/|~|\\$HOME)/",
        "reason": "moving or copying into an absolute or home path mutates outside the project — confirm",
        "tools": ["Bash"]
      },
      "Bash(chmod *)",
      "Bash(chown *)",
      {
        "regex": "\\bsudo\\b|\\bdoas\\b|\\bsu\\s+-",
        "reason": "privilege escalation — confirm before running",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bsystemctl\\s+(start|stop|restart|reload|enable|disable|mask|unmask)\\b",
        "reason": "systemd unit state change — confirm the target unit",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(service|launchctl)\\s+",
        "reason": "service control — confirm the target",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(kill|pkill|killall)\\b",
        "reason": "process termination — confirm the target",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(mount|umount)\\b",
        "reason": "mounting or unmounting a filesystem affects the whole host — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(apt|apt-get|yum|dnf|brew|pacman|zypper|apk)\\s+(install|remove|purge|upgrade|update|add|del|erase)\\b",
        "reason": "OS package install/remove — confirm before mutating the host",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bpip3?\\s+install\\b|\\bpipx\\s+install\\b|\\buv\\s+(pip\\s+)?install\\b",
        "reason": "installing a Python package — confirm before adding to the environment",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bnpm\\s+install\\s+(-g|--global)\\b|\\byarn\\s+global\\s+add\\b|\\bpnpm\\s+add\\s+(-g|--global)\\b",
        "reason": "installing a global node package — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bcargo\\s+install\\b|\\bgo\\s+install\\b|\\bgem\\s+install\\b",
        "reason": "installing a binary into the toolchain — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bcurl\\b[^\"]*\\s(-o|-O|--output)\\b",
        "reason": "curl downloading to disk — confirm the destination",
        "tools": ["Bash"]
      },
      "Bash(wget *)",
      "Bash(git push *)",
      {
        "regex": "\\bgit\\s+(reset\\s+--hard|clean\\s+-[fd]+|checkout\\s+--|branch\\s+-D|tag\\s+-d|push\\s+.*--force)",
        "reason": "destructive git operation — confirm before running",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bgh\\s+(pr|issue)\\s+(merge|close|delete)\\b|\\bgh\\s+release\\s+(create|delete)\\b",
        "reason": "gh CLI operation that mutates the remote project — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bdocker\\s+(run|rm|rmi|exec|build|push|stop|kill|prune|system\\s+prune)\\b",
        "reason": "docker operation with side effects — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(docker-compose|docker\\s+compose)\\s+(up|down|restart|rm|build|push)\\b",
        "reason": "docker-compose lifecycle operation — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bkubectl\\s+(apply|delete|patch|edit|scale|rollout|drain|cordon|uncordon|create|replace|exec|cp|port-forward)\\b",
        "reason": "kubectl operation with cluster side effects — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bhelm\\s+(install|upgrade|uninstall|rollback)\\b",
        "reason": "helm release change — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bterraform\\s+(apply|destroy|import|state\\s+(rm|mv))\\b|\\btofu\\s+(apply|destroy|import)\\b",
        "reason": "infrastructure change — confirm",
        "tools": ["Bash"]
      },
      {
        "regex": "\\b(ansible-playbook|ansible)\\s+",
        "reason": "ansible execution — confirm target hosts and playbook",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bssh\\s+[^\"]*\\s",
        "reason": "outbound SSH connection — confirm destination and command",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bnc\\s|\\bncat\\s|\\bsocat\\s",
        "reason": "raw network tool — confirm intent",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bcd\\s+/",
        "reason": "Changing directory to an absolute path escapes the project root — confirm the destination",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bcd\\s+~",
        "reason": "Changing directory into $HOME escapes the project root — confirm the destination",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bcd\\s+\\$",
        "reason": "Changing directory using a $VAR escapes the project root — confirm the destination",
        "tools": ["Bash"]
      },
      {
        "regex": "\\bpushd\\s+(/|~|\\$)",
        "reason": "pushd to an absolute, home, or $VAR path escapes the project root — confirm the destination",
        "tools": ["Bash"]
      },
      "install_remote_skill",
      "install_remote_item",
      "link_skill_to_agent"
    ]
  }
}
